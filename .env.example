# ── fastpoker client-standalone config ────────────────────────────────────
# LIGHT (default): no backend. The browser talks directly to a public L1 RPC and
# the MagicBlock TEE. Bring your own RPC. Copy this to .env.local and edit.

# Network: mainnet | devnet
NEXT_PUBLIC_SOLANA_CLUSTER=mainnet

# L1 RPC.
# BLANK = use the built-in rotating pool of free public RPCs (best-effort MVR).
# Static/CDN builds usually leave this blank so users may bring their own RPC in
# the app settings.
#
# Node-hosted public site: set NEXT_PUBLIC_L1_RPC_URL=/rpc and set server-side
# L1_RPC below. Then the browser uses your same-origin server RPC proxy and end
# users do not need their own RPC for normal use. Also set NEXT_PUBLIC_L1_WS_URL
# to your provider's WebSocket URL; the /rpc HTTP proxy cannot proxy WS.
#
# Local smoke example with a free Helius key:
# NEXT_PUBLIC_L1_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# NEXT_PUBLIC_L1_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Do not bake a private or high-value provider key into a public browser build.
NEXT_PUBLIC_L1_RPC_URL=
NEXT_PUBLIC_L1_WS_URL=
# Optional: override the public pool (comma-separated URLs).
# NEXT_PUBLIC_L1_RPC_POOL=https://solana-rpc.publicnode.com,https://solana.api.onfinality.io/public

# MagicBlock TEE (ephemeral rollup) endpoints. Per-player auth is a wallet-signed
# JWT minted client-side; no key needed for that.
NEXT_PUBLIC_DEFAULT_TEE_RPC=https://mainnet-tee.magicblock.app
NEXT_PUBLIC_DEFAULT_TEE_WS=wss://mainnet-tee.magicblock.app

# OPTIONAL: MagicBlock infra API key (Layer 1). NOT required — keyless works, just
# rate-limited. Leave blank; set only if you obtained your own key from MagicBlock.
NEXT_PUBLIC_TEE_API_KEY=

# OPTIONAL: Privy + embedded wallets. Disabled by default; the public source
# release is native-wallet only (Phantom / Backpack / Solflare) unless you opt in.
# Set BOTH your own app id and NEXT_PUBLIC_PRIVY_LOGIN_ENABLED=true. Then enable
# only the login methods you want shown. Do NOT use another operator's app id.
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_LOGIN_ENABLED=false
NEXT_PUBLIC_PRIVY_LOGIN_EMAIL=false
NEXT_PUBLIC_PRIVY_LOGIN_GOOGLE=false
NEXT_PUBLIC_PRIVY_LOGIN_X=false
NEXT_PUBLIC_PRIVY_LOGIN_APPLE=false

# OPTIONAL extension switches.
# Public profiles are read-only and wallet/indexer-derived. Set profiles or
# achievements to false/0 to hide those surfaces in your build.
NEXT_PUBLIC_ENABLE_PROFILES=true
NEXT_PUBLIC_ENABLE_ACHIEVEMENTS=true
# Indexed reads are opt-in. Set true only when INDEXER_BASE_URL points at your
# own running Indexer service. When false, the frontend uses RPC/local fallbacks.
NEXT_PUBLIC_ENABLE_INDEXER=false
NEXT_PUBLIC_ENABLE_INTEGRITY=

# OPTIONAL navbar visibility. These optional content pages ship in the nav and
# default to VISIBLE. Set one to 0/false/off to hide its navbar entry; the route
# itself stays reachable. Inlined at build time, so set before build/build:static.
NEXT_PUBLIC_NAV_EARN=true
NEXT_PUBLIC_NAV_AUCTIONS=true
NEXT_PUBLIC_NAV_DEALER=true
NEXT_PUBLIC_NAV_HOW_TO_PLAY=true

# OPTIONAL white-label branding. These values are baked into the build. Set
# before `npm run build` / `npm run build:static`, then rebuild after changing.
# The MIT license covers the code, not the FastPoker name, logos, token marks, or
# legal copy. Rebrand before shipping your own public fork.
NEXT_PUBLIC_BRAND_NAME=FAST POKER
NEXT_PUBLIC_BRAND_SHORT_NAME=FastPoker
NEXT_PUBLIC_BRAND_DOMAIN=fast.poker
NEXT_PUBLIC_BRAND_TAGLINE=On-Chain Texas Hold'em
NEXT_PUBLIC_BRAND_DESCRIPTION=Non-custodial, on-chain poker on Solana. TEE-attested shuffles. Your wallet, your table.
# Escape $ because Next env files expand $NAME references.
NEXT_PUBLIC_BRAND_TOKEN_SYMBOL=\$FP
NEXT_PUBLIC_BRAND_TWITTER=@fastdotpoker
NEXT_PUBLIC_BRAND_DISCORD_URL=https://discord.gg/fastpoker
NEXT_PUBLIC_BRAND_X_URL=https://x.com/fastdotpoker
NEXT_PUBLIC_BRAND_GITHUB_URL=https://github.com/FastPoker
NEXT_PUBLIC_BRAND_DOCS_URL=https://docs.fast.poker
NEXT_PUBLIC_BRAND_POWERED_BY_URL=https://paradice.ai
NEXT_PUBLIC_BRAND_POWERED_BY_NAME=PARADICE
NEXT_PUBLIC_BRAND_POWERED_BY_TAGLINE=Technologies
NEXT_PUBLIC_BRAND_LOGO=/brand/logo_horiz_offwhite.png
NEXT_PUBLIC_BRAND_FAVICON=/brand/favicon.png
NEXT_PUBLIC_BRAND_APPLE_ICON=/brand/app-icon.png
NEXT_PUBLIC_BRAND_OG_IMAGE=/brand/app-icon.png
# Colors accept hex values. Primary hi/lo auto-derive from primary when blank.
NEXT_PUBLIC_BRAND_PRIMARY="#F26A1F"
NEXT_PUBLIC_BRAND_PRIMARY_HI=
NEXT_PUBLIC_BRAND_PRIMARY_LO=
NEXT_PUBLIC_BRAND_AMBER="#FFC63A"
NEXT_PUBLIC_BRAND_GOLD="#D4B457"
NEXT_PUBLIC_BRAND_BONE="#F5F1E6"

# OPTIONAL: point at your own indexer for FULL indexed profile/history/lobby stats.
NEXT_PUBLIC_INDEXER_WS_URL=
# Server-side URL for the FULL source indexer when running `npm start`.
# Example: http://localhost:3001
INDEXER_BASE_URL=

# ── OPTIONAL: node/FULL relay server config ───────────────────────────────
# Not used by static LIGHT (`npm run build:static`). Required only when running
# `npm run build && npm start` and you want same-origin `/rpc`, `/api/tee/token`,
# `/api/cash-game/*`, and `/api/sitngos/ready`.
#
# Absolute server-side RPC URL. Required for node-hosted /rpc and relay routes.
# This stays server-side and is not exposed to browser JS. You may reuse the same
# provider/account as the indexer only if your quota can support both workloads.
L1_RPC=
# Alternative name accepted by the server RPC resolver.
L1_RPC_PROXY_UPSTREAM=
# Operator authority keypair JSON path. Used by relay routes for protocol-side
# helper txs and TEE auth. Never signs as a player wallet.
AUTHORITY_KEYPAIR_PATH=
# Server-side TEE endpoint and optional infra key.
TEE_RPC=https://mainnet-tee.magicblock.app
TEE_API_KEY=
# Production origin allowed to call mutating relay APIs.
APP_ORIGIN=http://localhost:3005

# Program IDs default to the live mainnet program; override only if needed.
# NEXT_PUBLIC_FASTPOKER_PROGRAM_ID=
# NEXT_PUBLIC_PERMISSION_PROGRAM_ID=

# ── OPTIONAL: operator frontend fee ───────────────────────────────────────
# Charge a small convenience fee on top of each entry, paid to YOUR wallet. It's
# appended as a SOL transfer to the same transaction as the buy-in, fully shown
# in the confirm modal and the JOIN price. Leave the wallet blank to disable.
# This is a frontend fee (only in builds you ship), separate from the on-chain
# buy-in / prize pool. Capped at 10% by code regardless of the bps value.
NEXT_PUBLIC_OPERATOR_FEE_WALLET=
# SNG fee: basis points on the buy-in (100 = 1%) plus an optional flat SOL add-on.
NEXT_PUBLIC_SNG_FEE_BPS=
NEXT_PUBLIC_SNG_FEE_FLAT_SOL=
# Cash fee: same model, applied to deposits/self-seat (cash self-seat is deferred,
# so these are read but dormant until the cash entry flow ships).
NEXT_PUBLIC_CASH_FEE_BPS=
NEXT_PUBLIC_CASH_FEE_FLAT_SOL=
# Optional absolute ceiling on the computed fee, in SOL. 0 / blank = no cap.
NEXT_PUBLIC_OPERATOR_FEE_CAP_SOL=
